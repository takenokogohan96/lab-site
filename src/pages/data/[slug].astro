---
import { client } from "../../lib/microcms";
import type { Page } from "../../lib/microcms";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const response = await client.get({ 
    endpoint: "pages",
    queries: { filters: 'type[contains]data' }
  });
  
  return response.contents.map((post: Page) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const response = await client.get({ 
  endpoint: "pages", 
  queries: { filters: `slug[equals]${slug}` } 
});
const post = response.contents[0] as Page;

// 万が一データが取得できなかった場合の安全策
if (!post) {
  return Astro.redirect('/404');
}
---
<Layout title={post.title}>
  <h1>{post.title}</h1>
  {post.published && <p>公開日: {new Date(post.published).toLocaleDateString('ja-JP')}</p>}
  <article set:html={post.content} />
</Layout>