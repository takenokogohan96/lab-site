---
import { client } from "../../lib/microcms";
import type { Page } from "../../lib/microcms";
import Layout from "../../layouts/Layout.astro";
import { renderToc } from "../../lib/toc";

export async function getStaticPaths() {
  const response = await client.get({ 
    endpoint: "pages",
    queries: { filters: 'type[contains]repo' }
  });
  
  return response.contents.map((post: Page) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const response = await client.get({ 
  endpoint: "pages", 
  queries: { filters: `slug[equals]${slug}` } 
});
const post = response.contents[0] as Page;

// 万が一データが取得できなかった場合の安全策
if (!post) {
  return Astro.redirect('/404');
}

const { toc, contentWithIds } = renderToc(post.content);
---
<Layout title={post.title} toc={toc}>
  <h1>{post.title}</h1>
  <div class="meta-info">
    {post.category && <span class="category-label">{post.category.name}</span>}
    {post.published && <span class="date">公開日: {new Date(post.published).toLocaleDateString('ja-JP')}</span>}
  </div>
  <article set:html={contentWithIds} />
</Layout>

<style>
  .meta-info {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
    color: #9ca3af;
  }
  .category-label {
    background-color: #3f3e4a;
    border: 1px solid #4b5563;
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
  }

  /* 記事内の画像スタイル調整 */
  article :global(img) {
    max-width: 80%;
    height: auto;
    display: block;
    margin: 2rem auto;
  }
</style>