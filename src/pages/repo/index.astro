---
import { client, groupPagesByCategory } from "../../lib/microcms";
import type { Page } from "../../lib/microcms";
import Layout from "../../layouts/Layout.astro";

const response = await client.get({
  endpoint: "pages",
  queries: { filters: "type[contains]repo" },
});
const pages = response.contents as Page[];
const sortedGroups = groupPagesByCategory(pages);
---

<Layout title="Report">
  <h1>Report 一覧</h1>
  {
    sortedGroups.map((group) => (
      <section class="category-section">
        <ul class="article-list">
          {group.items.map((page) => (
            <li>
              <div class="article-item">
                <span 
                  class="category-label" 
                  style={group.color ? { borderColor: group.color, color: '#fff' } : {}}
                >
                  {group.name}
                </span>
                <a href={`/repo/${page.slug}`} class="article-link">{page.title}</a>
                {page.published && <span class="date">({new Date(page.published).toLocaleDateString('ja-JP')})</span>}
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Layout>

<style>
  .category-section { margin-bottom: 0; }
  .article-list { 
    list-style: none; 
    padding-left: 0; 
    margin: 0;
  }
  .article-item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
  }
  .category-label {
    background-color: #3f3e4a;
    border: 1px solid #4b5563;
    padding: 0.1rem 0.4rem;
    border-radius: 2px;
    font-size: 0.7rem;
    white-space: nowrap;
  }
  .date {
    font-size: 0.85rem;
    color: #9ca3af;
  }
</style>