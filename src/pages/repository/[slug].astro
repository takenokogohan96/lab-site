---
import { client, formatColor } from "../../lib/microcms";
import type { Page } from "../../lib/microcms";
import Layout from "../../layouts/Layout.astro";
import { renderToc } from "../../lib/toc";

export async function getStaticPaths() {
  // data と repo の両方のタイプを含めて全件取得
  const response = await client.get({ 
    endpoint: "pages",
    queries: { 
      filters: 'type[contains]data[or]type[contains]repo',
      limit: 100,
    }
  });
  
  return response.contents.map((post: Page) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: Page;
}

const { post } = Astro.props;

// 万が一データが取得できなかった場合の安全策
if (!post) {
  return Astro.redirect('/404');
}

const { toc, contentWithIds } = renderToc(post.content);
---
<Layout title={post.title} toc={toc}>
  <div class="meta-info">
    {post.category && (
      <span 
        class="category-label" 
        style={post.category.color ? { 
          borderColor: formatColor(post.category.color), 
          color: '#fff' 
        } : {}}
      >
        {post.category.name}
      </span>
    )}
    {post.published && <span class="date">公開日: {new Date(post.published).toLocaleDateString('ja-JP')}</span>}
  </div>
  <h1>{post.title}</h1>
  <article set:html={contentWithIds} />
</Layout>

<style>
  .meta-info {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    color: #9ca3af;
  }
  h1 {
    margin-top: 0;
    margin-bottom: 1.5rem;
  }
  .category-label {
    background-color: #3f3e4a;
    border: 1px solid #4b5563;
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
  }
  article :global(img) {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 2rem auto;
    border-radius: 4px;
  }
</style>