---
import { client, formatColor } from "../../lib/microcms";
import type { Page } from "../../lib/microcms";
import Layout from "../../layouts/Layout.astro";
import { renderToc } from "../../lib/toc";

export async function getStaticPaths() {
  // data と repo の両方のタイプを含めて全件取得
  const response = await client.get({ 
    endpoint: "pages",
    queries: { 
      filters: 'type[contains]data[or]type[contains]repo',
      limit: 100,
    }
  });
  
  return response.contents.map((page: Page) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

interface Props {
  page: Page;
}

const { page } = Astro.props;

// 万が一データが取得できなかった場合の安全策
if (!page) {
  return Astro.redirect('/404');
}

const { toc, contentWithIds } = renderToc(page.content);
---
<Layout title={page.title} toc={toc}>
  <div class="meta-info">
    {page.category && (
      <span 
        class="category-label" 
        style={page.category.color ? { 
          borderColor: formatColor(page.category.color), 
          color: '#fff' 
        } : {}}
      >
        {page.category.name}
      </span>
    )}
    {page.published && <span class="date">公開日: {new Date(page.published).toLocaleDateString('ja-JP')}</span>}
  </div>
  <h1>{page.title}</h1>
  <article set:html={contentWithIds} />
</Layout>

<style>
  .meta-info {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
    color: #9ca3af;
  }
  .category-label {
    background-color: #3f3e4a;
    border: 1px solid #4b5563;
    padding: 0.1rem 0.5rem;
    border-radius: 2px;
  }
  /* 記事内の段落の行間のみ個別に維持 */
  article :global(p) { margin-bottom: 1.5rem; line-height: 1.75em; }
</style>