---
import { client } from "../lib/microcms";
import type { Page } from "../lib/microcms";
import Layout from "../layouts/Layout.astro";

// Repository（DataとReport）から最新の5件を取得してトップページに表示
const response = await client.get({
  endpoint: "pages",
  queries: {
    filters: "type[contains]data[or]type[contains]repo",
    limit: 5,
    orders: "-published",
  },
});
const latestPages = response.contents as Page[];
---

<Layout title="Home">
  <section class="hero">
    <h1>Welcome to Lab</h1>
    <p>工事中</p>
  </section>

  <section class="latest-section">
    <h2 class="section-title">Latest Updates</h2>
    <ul class="article-list">
      {latestPages.map((page) => (
        <li class="article-item">
          <span class="date">
            {page.published ? new Date(page.published).toLocaleDateString('ja-JP') : ''}
          </span>
          <a href={`/repository/${page.slug}`} class="article-link">
            {page.title}
          </a>
        </li>
      ))}
    </ul>
    <a href="/repository" class="more-link">
      View all repository &rarr;
    </a>
  </section>
</Layout>

<style>
  .hero {
    margin-bottom: 4rem;
  }
  .latest-section {
    margin-top: 2rem;
  }
  .section-title {
    font-size: 1.5rem;
    margin-bottom: 1.5rem;
  }
  .article-list { list-style: none; padding: 0; }
  .article-item {
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }
  .date { color: #9ca3af; font-size: 0.9rem; min-width: 100px; }
  .article-link { font-weight: 500; }
  .more-link {
    display: inline-block;
    margin-top: 2rem;
    font-weight: bold;
  }
</style>