---
import { client } from "../lib/microcms";
import type { IndependentPage } from "../lib/microcms";

const { title } = Astro.props;

// 固定ページAPI (f-pages) から基本情報を取得 [1]
const fPagesRes = await client.get({ endpoint: "f-pages" });
const fPages = fPagesRes.contents as IndependentPage[];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | Lab</title>
    <meta name="viewport" content="width=device-width" />
  </head>
  <body>
    <div class="container">
      <aside class="sidebar">
        <nav>
          {/* Webサイト名：リンクなし */}
          <div class="site-name">
            <h2>Lab.takeno.tech</h2>
          </div>
          
          {/* Generalセクション：サイトの基本情報 */}
          <section class="nav-section">
            <h3>General</h3>
            <ul class="nav-group">
              <li><a href="/">Home</a></li>
              {/* f-pages の「ページ名」と「スラッグ」をリスト表示 [1] */}
              {fPages.map(page => (
                <li><a href={`/${page.slug}`}>{page.title}</a></li>
              ))}
            </ul>
          </section>

          {/* Contentsセクション：メインコンテンツ */}
          <section class="nav-section">
            <h3>Contents</h3>
            <ul class="nav-group">
              {/* ページ種別（data/repo）の一覧への導線 [3] */}
              <li><a href="/data/">Database</a></li>
              <li><a href="/repo/">Report</a></li>
            </ul>
          </section>
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .container { display: flex; gap: 2.5rem; max-width: 1200px; margin: 0 auto; }
  .sidebar { width: 12rem; padding: 1rem 0.5rem; border-right: 1px solid #a2a9b1; min-height: 100vh; }
  
  .site-name h2 { font-size: 1rem; font-weight: bold; margin-bottom: 1.5rem; color: #000; }
  
  .nav-section h3 {
    font-size: 0.85rem;
    color: #54595d;
    margin-top: 1.5rem;
    border-bottom: 1px solid #a2a9b1;
    padding-bottom: 0.1rem;
    font-weight: normal;
  }

  .nav-group { list-style: none; padding: 0; margin: 0.5rem 0 1.5rem 0; }
  li { margin: 0.3rem 0; font-size: 0.875rem; }
  
  a { text-decoration: none; color: #0645ad; }
  a:hover { text-decoration: underline; }
  
  .content { flex: 1; padding: 1rem; }
</style>