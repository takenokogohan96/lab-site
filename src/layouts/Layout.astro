---
import { client } from "../lib/microcms";
import type { Page } from "../lib/microcms";

interface TocItem {
  id: string;
  text: string;
  level: number;
  children: TocItem[];
}

interface Props {
  title: string;
  toc?: TocItem[];
}

const { title, toc } = Astro.props;

// サイドバーに表示する固定ページ（type: general）を取得
const pagesResponse = await client.get({
  endpoint: "pages",
  queries: { filters: "type[contains]general" }
});
const generalPages = pagesResponse.contents as Page[];

---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | Lab</title>
    <meta name="viewport" content="width=device-width" />
  </head>
  <body>
    <header class="header">
      <button id="open-sidebar" class="icon-btn" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
      <div class="header-title">lab.takeno.tech</div>
    </header>

    <div class="container">
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <button id="close-sidebar" class="icon-btn" aria-label="Close menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <nav>
          {/* Generalセクション：サイトの基本情報 */}
          <section class="nav-section">
            <h3>General</h3>
            <ul class="nav-group">
              <li><a href="/">Home</a></li>
              {/* pages API のうち type が general のものを表示 */}
              {generalPages.map(page => (
                <li><a href={`/${page.slug}`}>{page.title}</a></li>
              ))}
            </ul>
          </section>

          {/* Pagesセクション：メインコンテンツ */}
          <section class="nav-section">
            <h3>Pages</h3>
            <ul class="nav-group">
              {/* ページ種別（data/repo）の一覧への導線 [3] */}
              <li><a href="/data/">Database</a></li>
              <li><a href="/repo/">Report</a></li>
            </ul>
          </section>

          {/* 目次セクション：記事詳細ページのみ表示 */}
          {toc && toc.length > 0 && (
            <section class="nav-section">
              <h3>Contents</h3>
              <ul class="nav-group toc-list">
                {toc.map(h2 => (
                  <li>
                    {h2.children.length > 0 ? (
                      <details>
                        <summary>
                          <a href={`#${h2.id}`}>{h2.text}</a>
                        </summary>
                        <ul>
                          {h2.children.map(h3 => (
                            <li>
                              <a href={`#${h3.id}`}>{h3.text}</a>
                              {h3.children.length > 0 && (
                                <ul class="toc-sub">
                                  {h3.children.map(h4 => (
                                    <li><a href={`#${h4.id}`}>{h4.text}</a></li>
                                  ))}
                                </ul>
                              )}
                            </li>
                          ))}
                        </ul>
                      </details>
                    ) : (
                      <a href={`#${h2.id}`}>{h2.text}</a>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          )}
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>

    <script>
      const sidebar = document.getElementById('sidebar');
      const openBtn = document.getElementById('open-sidebar');
      const closeBtn = document.getElementById('close-sidebar');

      openBtn?.addEventListener('click', () => {
        sidebar?.classList.add('active');
      });

      closeBtn?.addEventListener('click', () => {
        sidebar?.classList.remove('active');
      });
    </script>
  </body>
</html>

<style>
  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1rem;
    background: #fff;
    border-bottom: 1px solid #a2a9b1;
    position: sticky;
    top: 0;
    z-index: 100;
    height: 3rem;
  }

  .header-title { font-weight: bold; font-size: 1.1rem; }

  .icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    color: #54595d;
  }

  .icon-btn:hover { background-color: #f8f9fa; border-radius: 4px; }

  .sidebar-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.5rem;
  }

  /* デスクトップでは閉じるボタンを隠す */
  @media (min-width: 769px) {
    .sidebar-header, #open-sidebar { display: none; }
  }

  .container { display: flex; gap: 2.5rem; max-width: 1200px; margin: 0 auto; padding-top: 1rem; }
  
  .sidebar {
    width: 12rem;
    padding: 1rem 0.5rem;
    border-right: 1px solid #a2a9b1;
    background: #fff;
    position: sticky;
    top: 3rem; /* ヘッダーの高さ */
    height: calc(100vh - 3rem);
    overflow-y: auto;
  }
  
  .nav-section h3 {
    font-size: 0.85rem;
    color: #54595d;
    margin-top: 1.5rem;
    border-bottom: 1px solid #a2a9b1;
    padding-bottom: 0.1rem;
    font-weight: normal;
  }

  /* 最初のセクションの上部マージンを調整 */
  .nav-section:first-of-type h3 {
    margin-top: 0.5rem;
  }

  .nav-group { list-style: none; padding: 0; margin: 0.5rem 0 1.5rem 0; }
  li { margin: 0.3rem 0; font-size: 0.875rem; }
  
  .toc-list a { color: #54595d; }
  .toc-list li { margin-left: 0.2rem; }
  .toc-list a:hover { color: #0645ad; }
  .toc-list ul { list-style: none; padding-left: 1rem; border-left: 1px solid #eaecf0; margin: 0.2rem 0; }
  .toc-sub { padding-left: 0.8rem !important; font-size: 0.8rem; }

  .toc-list summary {
    cursor: pointer;
    display: flex;
    align-items: center;
    list-style: none;
  }
  /* デフォルトの矢印をカスタマイズ（三角形のアイコンを表示） */
  .toc-list summary::before {
    content: '▶';
    font-size: 0.6rem;
    margin-right: 0.4rem;
    color: #a2a9b1;
    transition: transform 0.2s;
  }
  .toc-list details[open] > summary::before { transform: rotate(90deg); }
  .toc-list summary::-webkit-details-marker { display: none; }

  a { text-decoration: none; color: #0645ad; }
  a:hover { text-decoration: underline; }
  
  .content { flex: 1; padding: 1rem; }

  /* モバイル対応のスタイル */
  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: -100%;
      top: 0;
      height: 100%;
      z-index: 200;
      transition: left 0.3s ease;
      box-shadow: 2px 0 5px rgba(0,0,0,0.1);
    }

    .sidebar.active { left: 0; }
  }
</style>