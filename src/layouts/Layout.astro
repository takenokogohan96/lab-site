---
import { client } from "../lib/microcms";
import type { Page } from "../lib/microcms";
import type { TocItem } from "../lib/toc";
import "../styles/global.css";

interface Props {
  title: string;
  toc?: TocItem[];
}

const { title, toc } = Astro.props;

// 現在のパスを取得（末尾のスラッシュを除去して比較しやすくする）
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

// サイドバーに表示する固定ページ（type: general）を取得
const pagesResponse = await client.get({
  endpoint: "pages",
  queries: { 
    filters: "type[contains]general",
    fields: "title,slug" 
  }
});
const generalPages = pagesResponse.contents as Page[];

---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | Lab</title>
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kode+Mono:wght@400..700&family=Noto+Sans+JP:wght@400..900&display=swap" rel="stylesheet">
  </head>
  <body>
    <button id="open-sidebar" class="icon-btn open-btn" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
    </button>

    <div class="container">
      <div id="sidebar-overlay" class="sidebar-overlay"></div>
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-header">
          <button id="close-sidebar" class="icon-btn" aria-label="Close menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <nav>
          {/* Menuセクション：サイトの基本情報 */}
          <section class="nav-section">
            <div class="nav-section-title">Menu</div>
            <ul class="nav-group">
              <li>
                {currentPath === "/" ? (
                  <span class="active-link">Home</span>
                ) : (
                  <a href="/">Home</a>
                )}
              </li>
              {generalPages.map(page => {
                const href = `/${page.slug}`;
                const isActive = currentPath === href;
                return (
                  <li>
                    {isActive ? (
                      <span class="active-link">{page.title}</span>
                    ) : (
                      <a href={href}>{page.title}</a>
                    )}
                  </li>
                );
              })}
            </ul>
          </section>

          {/* 目次セクション：記事詳細ページのみ表示 */}
          {toc && toc.length > 0 && (
            <section class="nav-section">
              <div class="nav-section-title">Contents</div>
              <ul class="nav-group toc-list">
                {toc.map(h2 => (
                  <li>
                    {h2.children.length > 0 ? (
                      <details>
                        <summary>
                          <a href={`#${h2.id}`}>{h2.text}</a>
                        </summary>
                        <ul>
                          {h2.children.map(h3 => (
                            <li>
                              <a href={`#${h3.id}`}>{h3.text}</a>
                              {h3.children.length > 0 && (
                                <ul class="toc-sub">
                                  {h3.children.map(h4 => (
                                    <li><a href={`#${h4.id}`}>{h4.text}</a></li>
                                  ))}
                                </ul>
                              )}
                            </li>
                          ))}
                        </ul>
                      </details>
                    ) : (
                      <a href={`#${h2.id}`}>{h2.text}</a>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          )}
        </nav>
      </aside>

      <main class="content">
        <slot />
        <footer class="footer">
          {/* フッター要素は今後追加 */}
        </footer>
      </main>
    </div>

    <script>
      const sidebar = document.getElementById('sidebar');
      const openBtn = document.getElementById('open-sidebar');
      const closeBtn = document.getElementById('close-sidebar');
      const overlay = document.getElementById('sidebar-overlay');

      const checkButtonVisibility = () => {
        const scrollPos = window.scrollY;
        const windowHeight = window.innerHeight;
        const bodyHeight = document.documentElement.scrollHeight;

        // 100px以上スクロールしたか、ページが短くてスクロールできないか、最下部に近い場合
        const shouldShow = scrollPos > 100 || bodyHeight <= windowHeight || (windowHeight + scrollPos) >= (bodyHeight - 50);
        openBtn?.classList.toggle('show', shouldShow);
      };

      const openSidebar = () => {
        sidebar?.classList.add('active');
        overlay?.classList.add('active');
      };

      const closeSidebar = () => {
        sidebar?.classList.remove('active');
        overlay?.classList.remove('active');
      };

      openBtn?.addEventListener('click', openSidebar);
      closeBtn?.addEventListener('click', closeSidebar);
      overlay?.addEventListener('click', closeSidebar);

      // スクロール、リサイズ、読み込み時に表示状態をチェック
      window.addEventListener('scroll', checkButtonVisibility, { passive: true });
      window.addEventListener('resize', checkButtonVisibility);
      
      // 初期実行
      checkButtonVisibility();
    </script>
  </body>
</html>