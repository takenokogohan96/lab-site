---
import { client } from "../lib/microcms";
import type { Page } from "../lib/microcms";

interface TocItem {
  id: string;
  text: string;
  level: number;
  children: TocItem[];
}

interface Props {
  title: string;
  toc?: TocItem[];
}

const { title, toc } = Astro.props;

// 現在のパスを取得（末尾のスラッシュを除去して比較しやすくする）
const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";

// サイドバーに表示する固定ページ（type: general）を取得
const pagesResponse = await client.get({
  endpoint: "pages",
  queries: { 
    filters: "type[contains]general",
    fields: "title,slug" 
  }
});
const generalPages = pagesResponse.contents as Page[];

---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <title>{title} | Lab</title>
    <meta name="viewport" content="width=device-width" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Kode+Mono:wght@400..700&family=Noto+Sans+JP:wght@400..900&display=swap" rel="stylesheet">
  </head>
  <body>
    <header class="header">
      <button id="open-sidebar" class="icon-btn" aria-label="Open menu">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"></line><line x1="3" y1="6" x2="21" y2="6"></line><line x1="3" y1="18" x2="21" y2="18"></line></svg>
      </button>
      <div class="header-title">lab.takeno.tech</div>
    </header>

    <div class="container">
      <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">lab.takeno.tech</div>
        <div class="sidebar-header">
          <button id="close-sidebar" class="icon-btn" aria-label="Close menu">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        <nav>
          {/* Menuセクション：サイトの基本情報 */}
          <section class="nav-section">
            <h3>Menu</h3>
            <ul class="nav-group">
              <li>
                {currentPath === "/" ? (
                  <span class="active-link">Home</span>
                ) : (
                  <a href="/">Home</a>
                )}
              </li>
              {generalPages.map(page => {
                const href = `/${page.slug}`;
                const isActive = currentPath === href;
                return (
                  <li>
                    {isActive ? (
                      <span class="active-link">{page.title}</span>
                    ) : (
                      <a href={href}>{page.title}</a>
                    )}
                  </li>
                );
              })}
              <li>
                {currentPath === "/repository" ? (
                  <span class="active-link">Repository</span>
                ) : (
                  <a href="/repository">Repository</a>
                )}
              </li>
            </ul>
          </section>

          {/* 目次セクション：記事詳細ページのみ表示 */}
          {toc && toc.length > 0 && (
            <section class="nav-section">
              <h3>Contents</h3>
              <ul class="nav-group toc-list">
                {toc.map(h2 => (
                  <li>
                    {h2.children.length > 0 ? (
                      <details>
                        <summary>
                          <a href={`#${h2.id}`}>{h2.text}</a>
                        </summary>
                        <ul>
                          {h2.children.map(h3 => (
                            <li>
                              <a href={`#${h3.id}`}>{h3.text}</a>
                              {h3.children.length > 0 && (
                                <ul class="toc-sub">
                                  {h3.children.map(h4 => (
                                    <li><a href={`#${h4.id}`}>{h4.text}</a></li>
                                  ))}
                                </ul>
                              )}
                            </li>
                          ))}
                        </ul>
                      </details>
                    ) : (
                      <a href={`#${h2.id}`}>{h2.text}</a>
                    )}
                  </li>
                ))}
              </ul>
            </section>
          )}
        </nav>
      </aside>

      <main class="content">
        <slot />
      </main>
    </div>

    <script>
      const sidebar = document.getElementById('sidebar');
      const openBtn = document.getElementById('open-sidebar');
      const closeBtn = document.getElementById('close-sidebar');

      openBtn?.addEventListener('click', () => {
        sidebar?.classList.add('active');
      });

      closeBtn?.addEventListener('click', () => {
        sidebar?.classList.remove('active');
      });
    </script>
  </body>
</html>

<style>
  :root {
    --font-main: 'Noto Sans JP', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-code: 'Kode Mono', monospace;
    --background-primary: #13151a;
    --background-secondary: #101115;
    --text-normal: #d1d5db;
    --text-muted: #888888;
    --text-accent: #99a8ff;
    --text-accent-low: #99a8ff60;
    --text-accent-mid: #99a8ffC0;
    --code-normal: #fde550;

    font-family: var(--font-main);
    background-color: var(--background-primary);
    color: var(--text-normal);
    letter-spacing: .025em;
  }

  /* グローバルな見出し・要素のスタイル定義 */
  :global(h1) {
    font-size: 32px !important;
    margin-bottom: 1.5rem;
  }

  :global(h2) {
    padding: 0.5em 0 !important;
    border-bottom: solid 2px var(--text-accent-mid) !important;
    margin: 3rem 0 1.5rem;
    line-height: 1.3;
  }

  :global(h3) {
    font-size: 18px !important;
    padding: 0.1em 0.5em !important;
    border-left: solid 5px var(--text-accent-low) !important;
    margin: 2rem 0 1rem;
    line-height: 1.4;
  }

  :global(img) {
    display: block !important;
    max-width: 90% !important;
    height: auto;
    margin: 2rem auto !important;
    border-radius: 5px !important;
    border: 1px solid var(--text-accent-mid) !important;
  }

  :global(code, pre) {
    font-family: var(--font-code) !important;
  }

  .header {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.5rem 1rem;
    background: #13151a;
    border-bottom: 1px solid #4b5563;
    position: sticky;
    top: 0;
    z-index: 100;
    height: 3rem;
  }

  .header-title {
    font-family: 'Kode Mono', monospace;
    font-weight: bold;
    font-size: 1.1rem;
  }

  .sidebar-brand {
    font-family: 'Kode Mono', monospace;
    font-weight: bold;
    font-size: 1.2rem;
    padding: 0.5rem;
    margin-bottom: 1rem;
    display: none; /* デフォルト（モバイル）では非表示 */
  }

  .icon-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    display: flex;
    align-items: center;
    color: #9ca3af;
  }

  .icon-btn:hover { background-color: #3f3e4a; border-radius: 4px; }

  .sidebar-header {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 0.5rem;
  }

  .container {
    display: flex;
    gap: 4rem; /* 線を消す代わりに余白を広げて境界を意識させる */
    max-width: 1200px;
    margin: 0 auto;
    align-items: flex-start; /* サイドバーの高さがコンテンツに引きずられないようにする */
  }
  
  .sidebar {
    width: 14rem;
    padding: 1rem 0.5rem;
    background: #13151a;
    box-sizing: border-box;
    overflow-y: auto;
  }

  /* デスクトップ表示の設定 */
  @media (min-width: 769px) {
    .header { display: none; }
    .sidebar-header, #open-sidebar { display: none; }
    .sidebar-brand { display: block; }
    .sidebar {
      position: sticky;
      top: 0; /* ヘッダーがないので最上部に固定 */
      height: 100vh;
    }
  }
  
  .nav-section h3 {
    font-size: 0.835rem;
    color: var(--text-muted);
    margin-top: 1.5rem;
    padding-bottom: 0.5rem;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  /* 最初のセクションの上部マージンを調整 */
  .nav-section:first-of-type h3 {
    margin-top: 0.5rem;
  }

  /* サイドバーの見出しはグローバルスタイルの影響を除外 */
  .nav-section h3 {
    border-left: none !important;
    padding-left: 0 !important;
  }

  .nav-group {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1.5rem 0;
  }
  .nav-group li {
    font-size: 0.875rem;
    list-style: none; /* デフォルトのリストスタイルを無効化 */
    position: relative; /* カスタムマーカーの位置指定のため */
  }
  
  /* サイドバー内のリンク共通：クリック判定を横いっぱいに広げ、上下の余白を確保 */
  .nav-group li a {
    display: block;
    padding: 0.35rem 0.5rem;
    border-radius: 4px; /* 将来的にホバー時の背景色などを入れる場合のために角を丸めておく */
  }

  /* 現在表示中のページのスタイル */
  .active-link {
    display: block;
    padding: 0.35rem 0.5rem;
    color: #fff;
    font-weight: bold;
  }

  /* 目次内のトグル(summary)の中のリンクも横いっぱいに広げる */
  .toc-list summary a {
    flex: 1;
  }
  
  /* 目次内のすべてのリスト項目に適用される基本スタイル */
  .toc-list li > a {
    padding-left: 1.2rem; /* 記号(▶▼)のスペースを確保するために左パディングのみ上書き */
  }

  /* summary（トグル）のスタイル */
  .toc-list summary {
    list-style: none; /* デフォルトのマーカーを非表示 */
    cursor: pointer;
    display: flex; /* アイコンとテキストを横並びにする */
    align-items: center;
    padding-left: 0; /* デフォルトのpaddingをリセット */
  }
  /* summaryのトグル記号 */
  .toc-list summary::before {
    content: '▶';
    font-size: 0.7rem;
    color: #6b7280;
  }
  /* detailsが開いている時のトグル記号 */
  .toc-list details[open] > summary::before {
    content: '▼';
  }
  .toc-list summary::-webkit-details-marker { display: none; } /* Webkit系のデフォルトマーカーを非表示 */

  .toc-list ul { list-style: none; padding-left: 1rem; margin: 0.2rem 0; } /* ネストされたリストのインデント */
  .toc-sub { padding-left: 0.8rem !important; font-size: 0.8rem; }

  :global(a),
  :global(a:visited) {
    text-decoration: none;
    color: #99A8FF;
  }

  :global(a:hover) {
    text-decoration: underline;
    color: #b3beff; /* #99A8FF よりわずかに明るい色 */
  }
  
  .content { flex: 1; padding: 1rem; }
  .content {
    flex: 1;
    padding: 1rem;
    padding-bottom: 4rem; /* 下部に余白を持たせてスクロールの終端を綺麗にする */
  }

  /* モバイル対応のスタイル */
  @media (max-width: 768px) {
    .sidebar {
      position: fixed;
      left: -100%;
      top: 0;
      height: 100%;
      z-index: 200;
      transition: left 0.3s ease;
      box-shadow: 2px 0 5px rgba(0,0,0,0.1);
    }

    .sidebar.active { left: 0; }
  }
</style>